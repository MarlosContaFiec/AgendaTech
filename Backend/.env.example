# ─── Banco de Dados ───────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=agendatech_bd
DB_USER=agendamento
DB_PASS=agendamento@123

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=TROQUE_POR_CHAVE_ALEATORIA_LONGA_E_SEGURA_256bits
JWT_REFRESH_SECRET=TROQUE_POR_OUTRA_CHAVE_DIFERENTE_E_SEGURA
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Upload de arquivos ───────────────────────────────────────
UPLOAD_MAX_MB=10
UPLOAD_PATH=./uploads

# ─── Jobs ─────────────────────────────────────────────────────
JOBS_ENABLED=true
JOB_NOTIFICACOES_CRON=0 * * * *
JOB_PONTUACAO_CRON=*/15 * * * *

# ─── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contatosagendatech@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=AgendaTech <contatosagendatech@gmail.com>
