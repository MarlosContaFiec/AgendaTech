# ─── Banco de Dados ───────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=agendatech_bd
DB_USER=agendamento
DB_PASS=CHANGE_ME_db_password

# ─── MySQL root (used by docker-compose) ─────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# ─── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_byte_hex_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_random_64_byte_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Upload de arquivos ───────────────────────────────────────
UPLOAD_MAX_MB=10
UPLOAD_PATH=./uploads

# ─── Jobs ─────────────────────────────────────────────────────
JOBS_ENABLED=true
JOB_NOTIFICACOES_CRON=0 * * * *
JOB_PONTUACAO_CRON=*/15 * * * *

# ─── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AgendaTech <noreply@example.com>
